# =============================================================================
# Variáveis de ambiente para desenvolvimento local
# =============================================================================
# Copie para .env e preencha com os valores reais:
#   cp .env.example .env
#
# O .env NUNCA é commitado (.gitignore já garante isso).
# Em produção os valores vêm do Secret do OpenShift — não deste arquivo.
# =============================================================================

# --- DB2 ---
DB2_HOST=
DB2_PORT=50000
DB2_DATABASE=
DB2_USER=
DB2_PASSWORD=

# --- Redis Sentinel ---
# Use o IP Tailscale da VM 1 com as portas dos 3 sentinels
# Os endereços são dos sentinels (fixos), não do master (que pode mudar no failover)
REDIS_SENTINEL_HOSTS=redis://100.64.0.X:26379,redis://100.64.0.X:26380,redis://100.64.0.X:26381
REDIS_PASSWORD=
